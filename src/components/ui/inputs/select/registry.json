{
  "name": "NativeSelect",
  "category": "Inputs",
  "type": "UI Component",
  "description": "Standard select component with custom minimalist styling and chevron icon.",
  "props": [
    {
      "name": "label",
      "type": "string",
      "required": false,
      "description": "Label text."
    },
    {
      "name": "options",
      "type": "Option[]",
      "required": true,
      "description": "Selectable options {value, label}."
    }
  ],
  "dependencies": ["lucide-react"],
  "variants": ["Default"]
}
